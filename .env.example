# HR Management System — Environment Variables
# Copy this file to .env and fill in real values for local development.
# For production (Render), set these in the Render dashboard instead.
# DO NOT commit .env to git — it is listed in .gitignore.

# --- Required ---
# Flask session signing key. Generate a secure one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# On Render, this is auto-generated by render.yaml (generateValue: true).
SECRET_KEY=replace-me-with-a-long-random-string

# --- Optional ---
# Set to "production" in deployed environments to:
#   - disable Flask debug mode
#   - set SESSION_COOKIE_SECURE=True (required for HTTPS)
# Defaults to development (hot-reload, HTTP cookies) when unset.
FLASK_ENV=development

# Port the Flask development server binds to locally. Ignored in production.
# Render assigns PORT automatically; do not set it here.
PORT=5000

# Comma-separated list of allowed CORS origins. If unset, defaults to local
# dev origins (127.0.0.1:5500, 127.0.0.1:8000, 127.0.0.1:5000, etc.).
# In production, set this to your deployed frontend URL, e.g.:
#   CORS_ORIGINS=https://hr-management-system.onrender.com
# Same-origin deployments can leave this unset.
CORS_ORIGINS=
